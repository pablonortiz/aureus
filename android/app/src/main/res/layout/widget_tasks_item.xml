<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/widget_item_background"
    android:padding="10dp"
    android:gravity="center_vertical">

    <!-- Checkbox -->
    <ImageView
        android:id="@+id/widget_item_checkbox"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:background="@drawable/widget_checkbox_unchecked"
        android:layout_marginEnd="10dp"
        android:contentDescription="Completar tarea" />

    <!-- Priority dot -->
    <ImageView
        android:id="@+id/widget_item_priority_dot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@android:drawable/presence_online"
        android:layout_marginEnd="8dp" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#f1f5f9"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/widget_item_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#94a3b8"
                android:textSize="10sp"
                android:visibility="gone"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/widget_item_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#64748b"
                android:textSize="10sp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
